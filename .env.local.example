# Toss Payments 테스트 클라이언트 키
# https://developers.tosspayments.com 에서 발급
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_gck_xxxxxxxxxxxxxxxx

# API Gateway URL (로컬: 게이트웨이 포트, 배포: 게이트웨이 도메인)
NEXT_PUBLIC_API_URL=http://localhost:8080

# 결제 API 경로 prefix (게이트웨이 → brewing-society-app)
NEXT_PUBLIC_PAY_API_PREFIX=/api/v1/bs
